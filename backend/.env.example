APP_NAME=FasoTontine API
APP_ENV=development
API_V1_PREFIX=/api/v1
# Add your Vercel domain after deployment, for example:
# BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://fasotontine.vercel.app
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
FASOTONTINE_DEBUG=false
# Required in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440
UPLOAD_DIR=.runtime/uploads
MAX_UPLOAD_SIZE_BYTES=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
# CNIB registration accepts JPG, PNG, WebP and PDF documents.

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/fasotontine
